java_binary(
    name = "dev_client",
    srcs = [],
    data = [
        "//game/26.2:game_client_assets",
        "//game/26.2:game_client_assets_version",
    ],
    env = {
        "LANG": "en_US.UTF8",
    },
    jvm_flags = [
        "-Dfabric.development=true",
        "-Ddev.launch.version=26.2-snapshot-4",
        "-Ddev.launch.type=client",
        "-Ddev.launch.assetsVersion=$(rlocationpath //game/26.2:game_client_assets_version)",
        "-Ddev.launch.mainClass=net.fabricmc.loader.impl.launch.knot.KnotClient",
        "-Xmx4G",
    ] + select({
        "@platforms//os:macos": ["-XstartOnFirstThread"],
        "//conditions:default": [],
    }),
    main_class = "top.fifthlight.fabazel.devlaunchwrapper.DevLaunchWrapper",
    runtime_deps = [
        "//game/26.2:game_client",
        "//game/26.2:game_client_libraries",
        # Classpath separator
        ":widget_factory",
        "//blazesdl/26.2:blazesdl_unmerged",
        "//combine/backend/minecraft/versions:26.2",
        "//combine/backend/minecraft/fabric/26.2",
        "//combine/backend/minecraft/fabric:meta_jar",
        "//rule/dev_launch_wrapper",
        "@maven_fabric_26_2//:io_github_llamalad7_mixinextras_fabric",
        "@maven_fabric_26_2//:net_fabricmc_fabric_language_kotlin",
        "@maven_fabric_26_2//:net_fabricmc_fabric_loader",
        "@maven_fabric_26_2//:net_fabricmc_sponge_mixin",
    ],
)
