    resources = glob(["resources/**"]),
    visibility = ["//visibility:public"],
    runtime_deps = [
        "//combine/theme/blackstone:blackstone_common",
        "//combine/theme/blackstone:blackstone_vanilla",
        "//combine/theme/oreui:oreui_common",
        "//combine/theme/oreui:oreui_vanilla",
    ],
    deps = [
        "//:compose",
        "//combine/backend/minecraft/game/26.2",
        "//combine/core/data",
        "//combine/core/layout",
        "//combine/core/modifier",
        "//combine/core/modifier/drawing",
        "//combine/core/modifier/placement",
        "//combine/core/modifier/scroll",
        "//combine/core/paint",
        "//combine/core/screen",
        "//combine/core/widget/layout",
        "//combine/data",
        "//combine/style",
        "//combine/theme/base",
        "//combine/theme/blackstone",
        "//combine/theme/oreui",
        "//combine/theme/vanilla",
        "//combine/widget",
        "//game/26.2:game_client_libraries",
        "@maven//:org_jetbrains_kotlinx_kotlinx_collections_immutable_jvm",
        "@maven_fabric_26_2//:com_terraformersmc_modmenu",
        "@maven_fabric_26_2//:net_fabricmc_fabric_api_fabric_api",
        "@maven_fabric_26_2//:net_fabricmc_fabric_api_fabric_key_mapping_api_v1",
        "@maven_fabric_26_2//:net_fabricmc_fabric_api_fabric_lifecycle_events_v1",
        "@maven_fabric_26_2//:net_fabricmc_fabric_loader",
